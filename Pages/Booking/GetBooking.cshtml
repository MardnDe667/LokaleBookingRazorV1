@page
@using LokaleBookingRazor.Models
@model LokaleBookingRazor.Pages.Booking.GetBookingModel

@{
}
<h1>Bookinger</h1>

<div class="row mb-3">
    <div class="col-12">
        <form method="post" class="d-flex align-items-end gap-3 flex-wrap">
            <input asp-for="SearchString" placeholder="Enter search term" />
            <button type="submit" asp-page-handler="Search" class="btn btn-dark btn-sm">Search</button>
        </form>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12">
        <form method="post" class="d-flex align-items-end gap-3 flex-wrap">
            <div class="d-flex flex-column">
                <label asp-for="StartTid" class="form-label mb-1"></label>
                <input asp-for="StartTid"
                       asp-format="{0:yyyy-MM-ddTHH:mm}"
                       class="form-control form-control-sm"
                       type="datetime-local" />
            </div>
            <div class="d-flex flex-column">
                <label asp-for="SlutTid" class="form-label mb-1"></label>
                <input asp-for="SlutTid"
                       asp-format="{0:yyyy-MM-ddTHH:mm}"
                       class="form-control form-control-sm"
                       type="datetime-local" />
            </div>
            <button type="submit" asp-page-handler="FilterTime" class="btn btn-dark btn-sm">Filter</button>

            <a class="btn btn-dark btn-sm" asp-page="/Booking/GetBooking">Reset</a>
        </form>
    </div>
</div>

<div class="row mb-3">
    <div class="col-12">
        <form method="post" class="d-flex align-items-center gap-3 flex-wrap">
            <div class="form-check form-switch m-0">
                <input asp-for="UserBookings" class="form-check-input" type="checkbox">
                <label class="form-check-label">Se personlige bookings?</label>
            </div>

            <button type="submit" asp-page-handler="PersonalBookings" class="btn btn-dark btn-sm">Filter</button>
        </form>
    </div>
</div>

@if (Model.Bookings != null)
{
    <div class="row">
        @foreach (var booking in Model.Bookings)
        {
            var bruger = Model.Brugere.FirstOrDefault(b => b.Id == booking.BrugerId);
            var lokale = Model.Lokaler.FirstOrDefault(l => l.Id == booking.LokaleId);

            if (lokale != null && lokale.Id == booking.LokaleId)
            {
                <div class="col-md-4 mb-4">
                    <div class="card room-card">
                        <div class="card-body d-flex flex-column">
                            <h4 class="card-title">@booking.Navn</h4>

                            <p class="card-text">@booking.Beskrivelse</p>

                            <ul class="list-unstyled">
                                <li><strong>Start Tid:</strong> @booking.StartTid</li>
                                <li><strong>Slut Tid:</strong> @booking.SlutTid</li>
                                <li><strong>Booket af:</strong> @bruger?.Brugernavn</li>
                                <li><strong>Lokale:</strong> @lokale?.Navn</li>
                            </ul>
                        </div>

                        @if (Model.CanEditOrDelete(booking))
                        {
                            <div class="d-flex gap-2 m-1">
                                <a class="btn btn-danger btn-sm"
                                   asp-page="/Booking/DeleteBooking"
                                   asp-route-id="@booking.Id">
                                    Delete
                                </a>

                                <a class="btn btn-success btn-sm"
                                   asp-page="/Booking/EditBooking"
                                   asp-route-id="@booking.Id">
                                    Edit
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
}