@page
@model LokaleBookingRazor.Pages.Login.LogInModel
@{
}
<div class="container">
    <div>
        @Model.Message
    </div>
    <form method="post">
        <div class="form-group">
            <label asp-for="Bruger.Brugernavn" class="col-form-label "></label>
            <div>
                <input asp-for="Bruger.Brugernavn" />
            </div>
        </div>
        <div class="form-group">
            <label asp-for="Bruger.Password" class="col-form-label"></label>
            <div>
                <input asp-for="Bruger.Password" />
            </div>
        </div>
        <div class="form-group">
            <button class="btn btn-outline-dark mt-3">Login</button>
        </div>

        <div class="action-buttons">
            <a class="btn btn-outline-dark mt-3" asp-page="/Login/CreateAccount">Create Account</a>
        </div>
    </form>
</div>