@page
@model LokaleBookingRazor.Pages.Login.LogInModel
@{
}
<div class="container">
    <div>
        @Model.Message
    </div>
    <form method="post">
        <div class="form-group">
            <label asp-for="Brugernavn" class="col-form-label "></label>
            <div>
                <input asp-for="Brugernavn" />
            </div>
        </div>
        <div class="form-group">
            <label asp-for="Password" class="col-form-label"></label>
            <div>
                <input asp-for="Password" />
            </div>
        </div>
        <div class="form-group">
            <button class="btn btn-outline-dark mt-3">Login</button>
        </div>

        <div class="form-group">
            <button class="btn btn-outline-dark mt-3">Opret Bruger</button>
        </div>
    </form>
</div>