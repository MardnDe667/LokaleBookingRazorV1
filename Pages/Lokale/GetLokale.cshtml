@page
@model LokaleBookingRazor.Pages.Lokale.GetLokaleModel
@{
}
<h1>Lokaler</h1>

<div class="row mb-3">
	<div class="col-12">
		<form method="post" class="d-flex align-items-end gap-3 flex-wrap">
			<input asp-for="SearchString" placeholder="Enter search term" />
			<button type="submit" asp-page-handler="Search" class="btn btn-dark btn-sm">Search</button>
		</form>
	</div>
</div>

<div class="d-flex align-items-center gap-2 mb-3">

	<span>Sorter alfabetisk:</span>

	<div class="col-auto">
		<form method="post">
			<button type="submit" asp-page-handler="SortAscending" class="btn btn-dark btn-sm">▲</button>
		</form>
	</div>
	<div class="col-auto">
		<form method="post">
			<button type="submit" asp-page-handler="SortDescending" class="btn btn-dark btn-sm">▼</button>
		</form>
	</div>
</div>

<div class="d-flex align-items-center gap-2 mb-3">

	<span>Sorter lokale type:</span>

	<div class="col-auto">
		<form method="post">
			<button type="submit" asp-page-handler="SortKlasseLokaler" class="btn btn-dark btn-sm">Klasse Lokaler</button>
		</form>
	</div>
	<div class="col-auto">
		<form method="post">
			<button type="submit" asp-page-handler="SortMødeLokaler" class="btn btn-dark btn-sm">Møde Lokaler</button>
		</form>
	</div>
	<div class="col-auto">
		<form method="post">
			<button type="submit" asp-page-handler="SortAuditorium" class="btn btn-dark btn-sm">Auditorium</button>
		</form>
	</div>
	<div class="col-auto">
		<form method="post">
			<button type="submit" asp-page-handler="SortGruppeLokaler" class="btn btn-dark btn-sm">Gruppe Lokaler</button>
		</form>
	</div>
</div>

<div class="row mb-3">
	<div class="col-12">
		<form method="post" class="d-flex align-items-center gap-3 flex-wrap">
			<label class="form-check-label">Sorter bygning:</label>
			<select asp-for="BygningInput" class="col-form-control">
				<option value="">Vælg Bygning</option>
				<option value="A">Bygning A</option>
				<option value="B">Bygning B</option>
				<option value="C">Bygning C</option>
			</select>

			<button type="submit" asp-page-handler="SortBygningTal" class="btn btn-dark btn-sm">Filter</button>
		</form>
	</div>
</div>

<div class="row">
    @if (Model.Lokaler != null)
    {
        foreach (var lokale in Model.Lokaler)
        {
            <div class="col-md-4 mb-4">
                <div class="card room-card">
                    <img class="card-img-top" src="~/Images/Logo v2.png" alt="Card image">

                    <div class="card-body d-flex flex-column">
						<h4 class="card-title">@lokale.Navn @lokale.BygningTal@lokale.SalNr.@lokale.LokaleNr</h4>

						<p class="card-text">@lokale.Beskrivelse</p>

                        <ul class="list-unstyled">
							<li><strong>Id:</strong> @lokale.Id</li>
							<li><strong>SmartBoard:</strong> @lokale.SmartBoard</li>
							<li><strong>Størrelse (Kvadratmeter):</strong> @lokale.Størrelse</li>
							@switch(lokale.Type)
							{
								case 1:
									<li><strong>Type:</strong> Klasse lokale</li>
									break;
								case 2:
									<li><strong>Type:</strong> Møde lokale</li>
									break;
								case 3:
									<li><strong>Type:</strong> Auditorium</li>
									break;
								case 4:
									<li><strong>Type:</strong> Gruppe lokale</li>
									break;
							}
                        </ul>

						<div class="action-buttons mb-3">
							<a class="btn btn-primary btn-sm"
							   asp-page="/Booking/CreateBooking"
							   asp-route-id="@lokale.Id">
								<strong class="fa-solid fa-pen">Create Booking</strong>
							</a>
						</div>

						@if (Model.Bookings != null)
						{
							foreach (var booking in Model.Bookings)
							{
								var bruger = Model.Brugere.FirstOrDefault(b => b.Id == booking.BrugerId);

								if (lokale.Id == booking.LokaleId)
								{
									<div class="d-flex flex-wrap gap-2 mb-3">
										<div class="card room-card">
											<div class="card-body d-flex flex-column">
												<h4 class="card-title">@booking.Navn</h4>

												<p class="card-text">@booking.Beskrivelse</p>

												<ul class="list-unstyled">
													<li><strong>Start Tid:</strong> @booking.StartTid</li>
													<li><strong>Slut Tid:</strong> @booking.SlutTid</li>
													<li><strong>Booket af:</strong> @bruger?.Brugernavn</li>
												</ul>
											</div>

											@if (Model.CanEditOrDelete(booking))
											{
												<div class="d-flex gap-2 m-1">
													<a class="btn btn-danger btn-sm"
													   asp-page="/Booking/DeleteBooking"
													   asp-route-id="@booking.Id">
														Delete
													</a>

													<a class="btn btn-success btn-sm"
													   asp-page="/Booking/EditBooking"
													   asp-route-id="@booking.Id">
														Edit
													</a>
												</div>
											}
										</div>
									</div>
								}
							}
						}
					</div>
                </div>
            </div>
        }
    }
</div>