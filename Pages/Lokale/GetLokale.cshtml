@page
@model LokaleBookingRazor.Pages.Lokale.GetLokaleModel
@{
}
<h1>Lokaler</h1>

@* <div class="card" style="width:500px">
	<img class="card-img-top" src="~/Logo.png" alt="Card image">

	<div class="card-img-overlay d-flex flex-column border-dark">
		<h4 class="card-title">Lokale 1</h4>
		<p class="card-text">Det her et klasse lokale på 1 sal. Med plads til 20 personer.</p> *@

<div class="row">
    @if (Model.Lokaler != null)
    {
        foreach (var item in Model.Lokaler)
        {
            <div class="col-md-4 mb-4">
                <div class="card room-card">
                    <img class="card-img-top" src="~/Logo.png" alt="Card image">

                    <div class="card-body d-flex flex-column">
                        <h4 class="card-title">@item.Navn</h4>

                        <p class="card-text">@item.Beskrivelse</p>

                        <ul class="list-unstyled">
                            <li><strong>Id:</strong> @item.Id</li>
                            <li><strong>SmartBoard:</strong> @item.SmartBoard</li>
                            <li><strong>Størrelse:</strong> @item.Størrelse</li>
                            <li><strong>Type:</strong> @item.Type</li>
                            <li><strong>Booking:</strong> @item.Booking</li>
                        </ul>

                        <a href="#" class="btn btn-primary mt-auto">
                            Opret Booking
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>

<table class="table table-bordered table-hover table-striped">
	<thead>
		<tr>
			<th>
				Name
			</th>
			<th>
				Beskrivelse
			</th>
			<th>
				SmartBoard
			</th>
			<th>
				Størrelse
			</th>
			<th>
				Type
			</th>
			<th>
				Booking
			</th>
		</tr>
	</thead>
	<tbody>
		@if (Model.Lokaler != null)
		{
			foreach (var item in Model.Lokaler)
			{
				<tr>
					<th>
						Id
					</th>
					<td>
						@item.Id
					</td>

					<td>
						@item.Navn
					</td>
				</tr>
			}
		}
	</tbody>